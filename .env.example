PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=your_mongodb_connection_string_here
# Optional: custom DNS servers for mongodb+srv lookups when Node cannot resolve SRV records
MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8

# JWT - Access Token (short-lived, used for API requests)
JWT_SECRET=fuelpass_access_secret_change_this_in_production
JWT_EXPIRES_IN=15m

# JWT - Refresh Token (long-lived, used to silently re-issue access tokens)
JWT_REFRESH_SECRET=fuelpass_refresh_secret_must_be_different_from_above
JWT_REFRESH_EXPIRES_IN=7d

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Socket.io
CLIENT_URL=http://localhost:5173

# Admin seed credentials (used by seed.js to create the first admin account)
ADMIN_EMAIL=admin@fuelpass.com
ADMIN_PASSWORD=Admin@1234